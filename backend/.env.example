DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nexgen?schema=public"
PORT=4000
NODE_ENV=development

JWT_SECRET="generate-a-long-random-string"

# Test mode (default while building): https://dashboard.stripe.com/test/apikeys
# Live mode (real charges): https://dashboard.stripe.com/apikeys — use sk_live_... and a LIVE webhook signing secret
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Comma-separated: local dev + your Netlify URL (and custom domain if any)
FRONTEND_URL="http://localhost:8080,https://your-site.netlify.app"

ADMIN_EMAIL="admin@nexgen.com"
ADMIN_PASSWORD="changeme123"

# Admin email when a booking is paid (Resend — https://resend.com)
# RESEND_API_KEY=re_...
# RESEND_FROM="NexGen <onboarding@resend.dev>"
# ADMIN_NOTIFY_EMAIL="you@gmail.com"
# PUBLIC_API_URL="https://your-api.onrender.com"
